{
  "name": "memeflash",
  "version": "1.0.15",
  "description": "Affiche les mèmes Discord en overlay pendant tes parties",
  "author": "MemeCorp",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "make-icon": "node scripts/make-icon.js",
    "build": "npm run make-icon && electron-builder --win --x64",
    "release": "npm run make-icon && electron-builder --win --x64 --publish always",
    "build-mac": "npm run make-icon && electron-builder --mac --publish never",
    "release-mac": "npm run make-icon && electron-builder --mac --publish always"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^35.3.0",
    "electron-builder": "^26.0.12",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.memecorp.memeflash",
    "productName": "MemeFlash",
    "copyright": "Copyright © 2025 MemeCorp",
    "directories": { "output": "dist" },
    "publish": [{
      "provider": "github",
      "owner": "ScanVerseFrance",
      "repo": "memeflash-releases"
    }],
    "win": {
      "icon": "build/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MemeFlash",
      "menuCategory": "MemeCorp",
      "include": "build/installer.nsh",
      "installerHeader": "build/header.bmp",
      "installerSidebar": "build/sidebar.bmp"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["universal"] }]
    },
    "files": [
      "main.js",
      "src/**/*",
      "node_modules/**/*",
      "build/icon.ico",
      "build/icon.png"
    ]
  }
}
